    "configuration": {
      "title": "Hiveku",
      "properties": {
        "hiveku.baseUrl": {
          "type": "string",
          "default": "https://core.hiveku.com",
          "description": "Base URL of the Hiveku MCP server (the /mcp endpoint is appended)."
        },
        "hiveku.appUrl": {
          "type": "string",
          "default": "https://app.hiveku.com",
          "description": "Base URL of the Hiveku web app (used by the browser Connect flow)."
        },
        "hiveku.includeAssetsOnDownload": {
          "type": "boolean",
          "default": true,
          "description": "Include binary assets (images, fonts, etc.) when downloading a project."
        },
        "hiveku.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Folder where Hiveku keeps your accounts + projects. Each account gets a subfolder, and projects nest under it (<root>/<account>/<project>). Leave blank to be prompted per account. Set via Hiveku: Guided Setup."
        },
        "hiveku.rootFolder": {
          "type": "string",
          "default": "",
          "description": "The Hiveku root folder. Every connected account gets its own folder here (sites, data, knowledge, briefs). Set once via \"Hiveku: Set Root Folder\"."
        },
        "hiveku.claudeCodePermissionMode": {
          "type": "string",
          "enum": [
            "acceptEdits",
            "bypassPermissions",
            "default"
          ],
          "enumDescriptions": [
            "Auto-approve file edits and safe in-folder commands; still ask before deploys, git push, network, and Hiveku writes. Recommended.",
            "Autonomous — skip permission prompts entirely (Claude Code runs account/site work without asking). Your .env*.local deny rule still blocks secret reads. Use when you trust Claude Code to operate an account end-to-end.",
            "Ask before every edit and command (most cautious)."
          ],
          "default": "acceptEdits",
          "markdownDescription": "How much autonomy Claude Code gets in Hiveku account/site workspaces. Written into each scaffolded folder's `.claude/settings.json` (`permissions.defaultMode`, for terminal Claude Code) and `.vscode/settings.json` (`claudeCode.initialPermissionMode`, for the Claude Code VS Code extension). Run **Hiveku: Refresh Setup** after changing this to apply it to already-open folders. The `.env*.local` deny rule is always enforced, even in `bypassPermissions`."
        },
        "hiveku.codexSupport": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Also scaffold OpenAI Codex support into Hiveku folders: `AGENTS.md`, a project-scoped `.codex/config.toml` carrying the folder's Hiveku MCP server + account key, and `.agents/skills/*` mirrors of every /hiveku-* command — so the Codex CLI / IDE extension works the same as Claude Code. Enable via **Hiveku: Set Up Codex Support** (it also offers to pre-trust your folders in `~/.codex/config.toml`, which Codex requires before loading project config)."
        }
      }
    },
