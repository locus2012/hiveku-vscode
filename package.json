      },
      {
        "command": "hiveku.downloadData",
        "title": "Hiveku: Download Department Data (local files for Claude Code)",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hiveku.copySetupPrompt",
        "title": "Hiveku: Connect Integration (copy Claude Code setup prompt)",
        "icon": "$(plug)"
      },
      {
        "command": "hiveku.newAutomation",
        "title": "Hiveku: New Local Automation (free cron + worker for Claude Code)",
        "icon": "$(watch)"
      },
      {
        "command": "hiveku.signOut",
