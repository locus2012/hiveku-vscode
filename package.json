    "viewsContainers": {
      "activitybar": [
        {
          "id": "hiveku",
          "title": "Hiveku",
          "icon": "media/hiveku.svg"
        }
      ]
    },
    "views": {
      "hiveku": [
        {
          "id": "hiveku.projects",
          "name": "Projects"
        },
        {
          "id": "hiveku.console",
          "name": "Account Console"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hiveku.projects",
        "contents": "Run your Hiveku accounts from the editor — projects, departments, media, and Claude scoped per account.\n[Guided Setup](command:hiveku.setup)\n\n[Connect Hiveku](command:hiveku.connect)\n\nPrefer to paste an API key?\n[Sign in with a key](command:hiveku.signIn)",
