{
  "name": "hiveku-vscode",
  "displayName": "Hiveku",
  "description": "Run entire Hiveku accounts from VS Code with Claude Code — role-based consoles for SEO, PPC, content, sales, outbound and bookkeeping; agency-grade methodology skills; site projects with native source control, deploys and previews; local automations and scheduled briefs.",
  "version": "0.70.2",
  "publisher": "hiveku",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/locus2012/hiveku-vscode.git"
  },
  "homepage": "https://hiveku.com",
  "bugs": {
    "url": "https://github.com/locus2012/hiveku-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hiveku.signIn",
        "title": "Hiveku: Sign In (add account key)"
      },
      {
        "command": "hiveku.setPermissionMode",
        "title": "Hiveku: Set Claude Code Autonomy…",
        "icon": "$(unlock)"
      },
      {
        "command": "hiveku.switchAccount",
        "title": "Hiveku: Switch Account"
      },
      {
        "command": "hiveku.setClaudeCodeAccount",
